# Copy to .env and fill in. NEVER commit the real .env.

# --- Required ---
PORT=3006
MONGO_URI=mongodb://localhost:27017/create_resume
SESSION_SECRET=change-me-to-a-long-random-string

# Origin of the frontend SPA (used for CORS + cookie). Dev default below.
CLIENT_ORIGIN=http://localhost:5173

# development | production
# In production the app sets a Secure + SameSite=None session cookie and trusts the
# reverse proxy (Cloudflare Tunnel) — so it MUST be served over HTTPS and CLIENT_ORIGIN
# must be the real frontend URL.
NODE_ENV=development
